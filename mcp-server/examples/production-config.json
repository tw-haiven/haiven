{
  "mcpServers": {
    "haiven-prompts": {
      "command": "python",
      "args": ["mcp_server.py"],
      "cwd": "/path/to/haiven/mcp-server",
      "env": {
        "HAIVEN_API_URL": "https://your-haiven-instance.com",
        "HAIVEN_SESSION_COOKIE": "your_session_cookie_here"
      }
    }
  }
} 